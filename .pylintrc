[MASTER]
ignore=CVS,venv,env,.venv,node_modules,migrations

[MESSAGES CONTROL]
# C: Convention, R: Refactor, W: Warning 
disable=
    # --- too strict ---
    C0114, # missing-module-docstring 
    C0115, # missing-class-docstring 
    C0116, # missing-function-docstring 
    C0103, # invalid-name 
    C0303,
    
    # --- conflict with modern programmer ---
    W0511, # fixme 
    W0703, # broad-except 
    W1203, # logging-fstring-interpolation 
    R0903, # too-few-public-methods 
    R0801, # duplicate-code 
    
    # --- other ---
    W0613, # unused-argument 
    W0212, # protected-access 

[FORMAT]
max-line-length=150

[BASIC]
# allow short var name（比如 i, j, k, ex, _, id）
good-names=i,j,k,ex,Run,_,id,db

[DESIGN]
max-args=7
max-attributes=10
max-locals=20
